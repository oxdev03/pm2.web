{
  "name": "backend",
  "version": "1.5.0",
  "main": "dist/index.js",
  "description": "Dashboard for PM2",
  "author": {
    "name": "oxdev03"
  },
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/oxdev03/pm2.web"
  },
  "bugs": {
    "url": "https://github.com/oxdev03/pm2.web/issues"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 0",
    "build": "tsc --build --clean && tsc",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,json,css,scss,md}\"",
    "format:check": "prettier --check  \"**/*.{ts,json,css,scss,md}\"",
    "prestart": "tsc --build --clean && tsc",
    "watch": "tsc -w",
    "dev": "dotenv -v DB_URI=mongodb://127.0.0.1:27018/ -- pnpm run start",
    "dev:pm2": "node scripts/start-pm2.mjs"
  },
  "license": "LGPL-3.0-or-later",
  "dependencies": {
    "@pm2.web/mongoose-models": "workspace:*",
    "@pm2.web/typings": "workspace:*",
    "bcrypt": "^6.0.0",
    "bytes-iec": "^3.1.1",
    "dotenv": "^17.4.2",
    "mongoose": "^9.7.1",
    "pm2": "^7.0.1",
    "systeminformation": "^5.31.7"
  },
  "devDependencies": {
    "@pm2.web/eslint-config": "workspace:*",
    "@pm2.web/typescript-config": "workspace:*",
    "@types/bcrypt": "^6.0.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.5.0",
    "typescript": "^6.0.3"
  }
}
